PORT=4000
DATABASE_URL=mysql://root:password@localhost:3306/dispatch

# Set to "true" when the API runs behind a reverse proxy / load balancer so the
# real client IP (X-Forwarded-For) is used for rate limiting. Leave unset
# otherwise to avoid clients spoofing their IP.
TRUST_PROXY=true

# Comma-separated list of browser origins allowed to call the API (your web
# app's URL). Required in production; localhost is auto-allowed in development.
CORS_ORIGINS=https://app.yourdomain.com

# Gmail account used to send transactional email (verification codes).
# GMAIL_APP_PASSWORD is a 16-char App Password, not your normal login password:
# https://myaccount.google.com/apppasswords
GMAIL_USER=you@gmail.com
GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx

# Public URL of the web app — used to build links in emails (password reset).
FRONTEND_URL=http://localhost:3000

# Set to "true" only when self-hosting and you intentionally fire webhooks at
# private/internal addresses. Leave unset in the cloud — it disables the SSRF
# guard that blocks webhooks pointed at internal services and cloud metadata.
ALLOW_PRIVATE_WEBHOOKS=false
